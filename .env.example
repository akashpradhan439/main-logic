# ─────────────────────────────────────────────────────────────────────────────
# Lokaal — example environment file.
# Copy to `.env` and fill in real values. NEVER commit your real .env.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Auth / Database (Supabase) ───────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
QR_ENCRYPTION_KEY=32-byte-hex-for-aes-256-qr-payloads

# ── Redis (swarm blackboard + cache; Azure Cache for Redis in prod) ──────────
# Use rediss:// for a TLS-secured managed instance.
REDIS_URL=rediss://default:password@your-redis-host:6380

# ── Microsoft AI: Azure AI Foundry (powers all 4 swarm agents + assistant) ───
# Serverless / OpenAI-compatible endpoint. The deployment is the model name.
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/models
AZURE_OPENAI_API_KEY=your-azure-ai-foundry-key
AZURE_OPENAI_DEPLOYMENT=Llama-3.3-70B-Instruct

# ── Microsoft AI: Azure AI Content Safety (Critic agent safety gate; optional) ─
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-content-safety.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key

# ── Places / Location data ───────────────────────────────────────────────────
FOURSQUARE_API_KEY=your-foursquare-places-api-key
OLA_MAPS_API_KEY=your-ola-maps-key            # used by the n8n meetup-spots workflow

# ── Messaging / Event bus (RabbitMQ) ─────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=app.events

# ── Apple Push Notifications (APNs) — for the messaging/proximity workers ─────
APNS_KEY_PATH=./AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.yourcompany.app

# ── n8n automation layer (events scraper + meetup workflows) ─────────────────
N8N_WEBHOOK_SECRET=shared-secret-between-fastify-and-n8n
N8N_MEETUP_WEBHOOK_URL=http://n8n:5678/webhook/meetup-spots
N8N_MEETUP_SUGGESTIONS_WEBHOOK_URL=http://n8n:5678/webhook/meetup-suggestions
N8N_EVENTS_SCRAPER_WEBHOOK_URL=http://n8n:5678/webhook/events-scraper

# ── Dev / testing flags ──────────────────────────────────────────────────────
# Set to true to run without the dependency (handy for local swarm-only testing).
SKIP_RABBITMQ=false
SKIP_REDIS=false
